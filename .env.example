# Copy this file to `.env` and adjust for your environment.

# Backend origin (used to derive the API base URL when VITE_API_BASE_URL is unset).
VITE_BACKEND_BASE=http://localhost:5500

# Optional: full REST API base URL. Defaults to `${VITE_BACKEND_BASE}/api/v1`.
# VITE_API_BASE_URL=http://localhost:5500/api/v1

# Optional: localStorage key used to persist the auth token. Defaults to "qayd_token".
# VITE_AUTH_TOKEN_KEY=qayd_token
